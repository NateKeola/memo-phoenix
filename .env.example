# Memo Phoenix environment. Copy to .env.local and fill in real values.
# Supabase project: memo-phoenix (ref azlobwtiptvarfeukzcv).

# Public values. Safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://azlobwtiptvarfeukzcv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. NEVER prefix with NEXT_PUBLIC_. Bypasses RLS by design.
# Used by the telemetry writer (PR0) and the miner (PR1).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used by the Supabase CLI and the migrate-on-merge workflow.
SUPABASE_PROJECT_REF=azlobwtiptvarfeukzcv

# Supabase personal access token (account -> Access Tokens). The SAME value as the
# SUPABASE_ACCESS_TOKEN GitHub Actions secret. Needed locally only for the
# CLI-independent migration fallback `npm run db:status` / `npm run db:apply`
# (Supabase Management API over HTTPS, no CLI, no DB password). See docs/MIGRATIONS.md.
# SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# --- Miner (PR1), used by `npm run miner` / `npm run seed` (CLI worker) ---
# Anthropic API key for extraction + resolution. Server-only.
ANTHROPIC_API_KEY=your-anthropic-key
# The single user's id (the auth.users id of the one account). The miner uses the
# service-role client, which has no auth.uid(), so it stamps user_id explicitly.
MEMO_USER_ID=your-user-uuid
# Optional miner tuning:
# MINER_MODEL=claude-opus-4-8
# MINER_EFFORT=high            # low|medium|high|xhigh|max; lower to shrink thinking's share of the token budget
# MINER_PAGE_SIZE=40           # max nodes emitted per LLM call (default 40); the primary anti-truncation lever
# MINER_MAX_TOKENS=24000       # non-streaming output ceiling (default 24000); headroom so thinking + a page never truncate
# MINER_CHURN_DEBUG=1   # logs an A/B per table: provenance-sig writes vs old full-sig would-write

# --- Capture surface (PR2): Add memo speech-to-text ---
# ElevenLabs Scribe API key. Server-only (the memo STT route runs server-side);
# never expose to the browser. The deploy network allowlist must reach
# api.elevenlabs.io.
ELEVENLABS_API_KEY=your-elevenlabs-key
# Optional STT model override (default scribe_v1):
# ELEVENLABS_STT_MODEL=scribe_v1

# --- Interview agent (PR3) ---
# The ElevenLabs Conversational AI agent id. This is a PUBLIC value (the client
# connects to it via a server-minted signed URL). Reuses ELEVENLABS_API_KEY
# server-side for the signed-URL mint and transcript fetch.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your-agent-id
# How the companion addresses you in the bible ({{user_name}}). Falls back to the
# email local-part, then "there".
MEMO_USER_NAME=your-name

# --- Search and chat surface (PR6) ---
# The chat composer reuses ANTHROPIC_API_KEY (server-side; the chat route runs on
# the server). Optional tuning of the composing stage:
# CHAT_MODEL=claude-opus-4-8
# CHAT_EFFORT=medium
# CHAT_MAX_TOKENS=2048

# --- Companion (conversational follow-ups) ---
# The companion surfaces follow-ups and brainstorms next steps with you; it does
# NOT send email or create calendar events in V0 (that sending layer, with Google
# OAuth and SSO, is a later settings/connectors build). The brainstorm reuses
# ANTHROPIC_API_KEY (server-side); no extra config is needed.

# --- B2: invite-only beta + off-machine miner runtime ---
# The operator who may invite others (the /admin invite console is gated to them).
# A single-operator allowlist, not roles. Falls back to MEMO_USER_ID if unset.
MEMO_ADMIN_EMAIL=operator@example.com
# REQUIRED in the deployed environment. The base URL used to build the invite and
# sign-in redirect links (.../auth/callback). Set it to the deployed domain. Without
# it, an invite generated in a deployed context REFUSES LOUDLY (no silent localhost
# link); set it both in Vercel AND in your local .env.local if you ever generate
# invites from local dev. It must ALSO be in the Supabase Auth Site URL + Redirect
# URLs allowlist. See the README and docs/HANDOFF.md operator checklist.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# --- Password recovery ---
# SELF-SERVICE is the real path: on /forgot-password the user enters their email and
# Supabase emails them a reset link (supabase.auth.resetPasswordForEmail); it lands on
# /reset-password where they set a new password. No admin, no env flag. It is
# allowlist-scoped (a send happens only for the operator's own email or an active
# invite) and enumeration-safe (same neutral message either way).
#
# REQUIRES (operator, one-time):
#   1. Custom SMTP configured in Supabase (Authentication -> Emails/SMTP; Resend
#      recommended with a verified sender domain). The built-in Supabase sender is
#      rate-limited and unreliable; do not rely on it. SMTP is now configured.
#   2. NEXT_PUBLIC_SITE_URL set (above) AND `${NEXT_PUBLIC_SITE_URL}/auth/callback` in
#      the Supabase Auth Redirect URLs allowlist, so the link routes through the
#      callback (which establishes the session) and never falls back to the site root.
#   3. RECOMMENDED for cross-device recovery: set the Supabase "Reset Password" email
#      template link to
#      `{{ .SiteURL }}/auth/callback?token_hash={{ .TokenHash }}&type=recovery&next=/reset-password`
#      (stateless verifyOtp; works when the link is opened on another device). With the
#      default template it uses the PKCE code flow, which works when the link is opened
#      in the same browser that requested it.
#
# FALLBACK (not in the user path): /admin "Generate recovery link" mints a link with no
# email (service-role generateLink). Kept for the operator; nothing tells users to use
# it. No env flag: self-service is unconditional now.

# Off-machine miner. Primary path is the Vercel Pro run route (no config needed).
# Set this to offload the recompute to the GitHub Action instead (survives a closed
# tab and any serverless ceiling). Requires the two GitHub values below.
# MINER_USE_GITHUB_ACTION=1
# A fine-grained PAT for THIS repo with "contents: write" (repository_dispatch),
# and the repo in owner/repo form. Server-only; never exposed to the browser.
# GITHUB_DISPATCH_TOKEN=your-fine-grained-pat
# GITHUB_REPO=owner/repo
# Optional: reclaim a crashed 'running' miner_runs row older than this many ms
# (default 1200000 = 20 min).
# MINER_STALE_RUN_MS=1200000
# Auto-run threshold: trigger an automatic background mine once this many new
# captures have accumulated since the last successful run. Default 10. Governs
# background re-mining during normal app use only (not onboarding). Overrides the
# AUTO_RUN_NEW_CAPTURES code constant.
# MINER_AUTORUN_NEW_CAPTURES=10
#
# Headless background mining (Phase 2 Task C). A scheduled Vercel Cron
# (vercel.json -> /api/cron/miner-sweep, default hourly: "0 * * * *") sweeps every
# user and kicks off the GitHub Action for anyone over the threshold, so mining
# happens with no open tab. Set CRON_SECRET to gate the route (Vercel Cron sends it
# as a Bearer token). The sweep needs GITHUB_DISPATCH_TOKEN + GITHUB_REPO (above) to
# reach the Action; without them it skips cleanly. Change the cadence in vercel.json.
# CRON_SECRET=a-long-random-string
#
# The miner GitHub Action (.github/workflows/miner.yml) needs these Actions secrets:
#   NEXT_PUBLIC_SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, ANTHROPIC_API_KEY
# (optional MINER_MODEL, MINER_EFFORT). See docs/HANDOFF.md.
